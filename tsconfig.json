{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "lucide-react/dist/esm/icons/*.mjs": ["apps/web/src/lucide-icon.d.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/fly.tsbuildinfo",
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["apps/web/src", "packages/**/*.ts"]
}
